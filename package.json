{
  "name": "multi-integer-range",
  "version": "6.0.0",
  "description": "Parses and manipulates multiple comma-separated integer ranges (eg 1-3,8-10)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smikitky/node-multi-integer-range.git"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "test": "c8 tsx --test src/*.test.ts",
    "doc": "node scripts/docgen.js",
    "clean": "rimraf lib",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "prettier": "prettier --write src/**/*.{ts,js}"
  },
  "keywords": [
    "integer",
    "range",
    "page",
    "multiple",
    "parseInt",
    "parse"
  ],
  "author": "Soichiro Miki",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "c8": "^11.0.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "singleQuote": true,
    "arrowParens": "avoid",
    "trailingComma": "none"
  },
  "c8": {
    "reporter": [
      "lcov",
      "text"
    ]
  },
  "runkitExampleFilename": "example.js"
}
